{
  "name": "redirect",
  "description": "Open Redirect Patterns",
  "severity": "medium",
  "patterns": [
    {
      "name": "redirect_param",
      "pattern": "[?&](redirect|return|next|url|dest|callback|continue|redir)\\s*=\\s*http",
      "description": "Redirect Parameter",
      "severity": "high"
    },
    {
      "name": "redirect_relative",
      "pattern": "\\/\\/[^\\/\\s]+|\\/\\/[a-zA-Z0-9]",
      "description": "Protocol Relative Redirect",
      "severity": "medium"
    },
    {
      "name": "redirect_meta",
      "pattern": "<meta[^>]+url\\s*=",
      "description": "Meta Tag Redirect",
      "severity": "low"
    },
    {
      "name": "redirect_location",
      "pattern": "Location:\\s*http",
      "description": "HTTP Location Header",
      "severity": "medium"
    }
  ]
}
