{
  "name": "ssrf",
  "description": "Server-Side Request Forgery Patterns",
  "severity": "critical",
  "patterns": [
    {
      "name": "ssrf_localhost",
      "pattern": "localhost|127\\.0\\.0\\.1|0\\.0\\.0\\.0",
      "description": "Localhost Access",
      "severity": "high"
    },
    {
      "name": "ssrf_metadata",
      "pattern": "169\\.254\\.169\\.254|metadata\\.googleusercontent\\.com",
      "description": "Cloud Metadata Service",
      "severity": "critical"
    },
    {
      "name": "ssrf_internal_ip",
      "pattern": "10\\.\\d+\\.\\d+\\.\\d+|172\\.(1[6-9]|2\\d|3[01])\\.\\d+\\.\\d+|192\\.168\\.\\d+\\.\\d+",
      "description": "Internal IP Address",
      "severity": "high"
    },
    {
      "name": "ssrf_url_param",
      "pattern": "[?&](url|uri|src|dest|redirect|path|continue|url|data|rturl|next|redir|reference|site|html|val|validate|domain|callback|return|page|feed|host|port|to|out|view|dir|show|navigation|open|file|document|folder|pg|style|doc|img|filename|name|source|source_url|data_url|req|url|name|reg|code)\\s*=\\s*http",
      "description": "URL Parameter SSRF",
      "severity": "high"
    },
    {
      "name": "ssrf_file_protocol",
      "pattern": "file:///.*|dict://|sftp://|ldap://|gopher://",
      "description": "Dangerous URL Protocols",
      "severity": "critical"
    }
  ]
}
