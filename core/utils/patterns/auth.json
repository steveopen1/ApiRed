{
  "name": "auth",
  "description": "Authentication Issues Patterns",
  "severity": "high",
  "patterns": [
    {
      "name": "auth_jwt",
      "pattern": "Bearer\\s+[a-zA-Z0-9_-]+\\.[a-zA-Z0-9_-]+\\.[a-zA-Z0-9_-]+",
      "description": "JWT Token",
      "severity": "medium"
    },
    {
      "name": "auth_basic",
      "pattern": "Basic\\s+[a-zA-Z0-9]+=*",
      "description": "Basic Auth",
      "severity": "low"
    },
    {
      "name": "auth_api_key",
      "pattern": "[?&]?api[_-]?key\\s*=\\s*['\"]?[a-zA-Z0-9]{20,}",
      "description": "API Key in URL",
      "severity": "high"
    },
    {
      "name": "auth_password",
      "pattern": "[?&]?password\\s*=\\s*['\"]?[a-zA-Z0-9!@#$%^&*()]+",
      "description": "Password in URL",
      "severity": "critical"
    },
    {
      "name": "auth_session",
      "pattern": "(JSESSIONID|PHPSESSID|ASP\\.NET_SessionId)\\s*=",
      "description": "Session ID Exposure",
      "severity": "medium"
    }
  ]
}
